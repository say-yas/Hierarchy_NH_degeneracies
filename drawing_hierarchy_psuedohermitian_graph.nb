Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "sort", " ", "elements", " ", "of", " ", "chormosome", " ", "list", " ", 
    "to", " ", "prevent", " ", "duplication", " ", "in", " ", "nodes"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"sortChromosomeCompact", "[", "chromosome_List", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"groupedByValue", ",", "sortedGroups"}], "}"}], ",", 
     RowBox[{
      RowBox[{"groupedByValue", "=", 
       RowBox[{"GatherBy", "[", 
        RowBox[{"chromosome", ",", 
         RowBox[{
          RowBox[{"ToExpression", "[", 
           RowBox[{"StringDrop", "[", 
            RowBox[{"#", ",", 
             RowBox[{"-", "1"}]}], "]"}], "]"}], "&"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"sortedGroups", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"SortBy", "[", 
           RowBox[{"#", ",", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"StringEndsQ", "[", 
                RowBox[{"#", ",", "\"\<+\>\""}], "]"}], ",", "0", ",", "1"}], 
              "]"}], "&"}]}], "]"}], "&"}], ",", "groupedByValue"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"sortedGroups", "=", 
       RowBox[{"SortBy", "[", 
        RowBox[{"sortedGroups", ",", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"ToExpression", "[", 
            RowBox[{"StringDrop", "[", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", 
              RowBox[{"-", "1"}]}], "]"}], "]"}]}], "&"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Flatten", "[", "sortedGroups", "]"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.963168268741337*^9, 3.963168322950019*^9}, {
  3.963168997646792*^9, 3.963169000084943*^9}, {3.963169091390585*^9, 
