Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "find", " ", "all", " ", "possible", " ", "mutations", " ", "from", " ", 
    "a", " ", "given", " ", "chromosome"}], "*)"}], 
  RowBox[{
   RowBox[{"findAllMutations", "[", 
    RowBox[{"chromosome_List", ",", 
     RowBox[{"maxValue_Integer", ":", "40"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"allMutations", "=", 
        RowBox[{"{", "}"}]}], ",", "results"}], "}"}], ",", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"mutationType", "==", "\"\<8.2\>\""}], "&&", 
                RowBox[{"m", "<=", "1"}]}], ",", 
               RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"\"\<8.1\>\"", ",", "\"\<8.3\>\""}], "}"}], ",", 
                  "mutationType"}], "]"}], "&&", 
                RowBox[{"m", "<", "0"}]}], ",", " ", 
               RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"results", "=", 
              RowBox[{"applyMutation", "[", 
               RowBox[{
               "chromosome", ",", "mutationType", ",", "m", ",", "n"}], 
               "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Length", "[", "results", "]"}], ">", "0"}], ",", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"allMutations", ",", 
                 RowBox[{"{", 
                  RowBox[{
                  "mutationType", ",", "m", ",", "n", ",", "results"}], 
                  "}"}]}], "]"}]}], "]"}], ";"}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "m", ",", "maxValue"}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "1", ",", "maxValue"}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"mutationType", ",", 
          RowBox[{"{", 
           RowBox[{"\"\<8.1\>\"", ",", "\"\<8.2\>\"", ",", "\"\<8.3\>\""}], 
           "}"}]}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
      "allMutations"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{
