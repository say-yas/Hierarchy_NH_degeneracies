Cell["\<\
Mutation rules are from D. Djokovic, \[OpenCurlyDoubleQuote]Closures of \
Conjugacy Classes in Classical Real Linear Lie Groups. II\
\[CloseCurlyDoubleQuote], Transactions of the American Mathematical Society \
270,1 (1982).

Eq. (8.1): \
g^\[Epsilon](m)+g^(-\[Epsilon])(n)\[RightArrow]g^(-\[Epsilon])(m-1)+g^\
\[Epsilon](n+1)     m <=n
Eq. (8.2): g^\[Epsilon](m)+g^\[Epsilon](n)\[RightArrow]g^\[Epsilon](m-2)+g^\
\[Epsilon](n+2)             1<m<=n
Eq. (8.3): \
g_\[Epsilon](m)+g_{-\[Epsilon]}(n)\[RightArrow]g_{-\[Epsilon]}(m-1)+g_\
\[Epsilon](n+1)    m<=n
\
\>", "Text",
 CellChangeTimes->{{3.963152714336275*^9, 3.963152721155937*^9}, {
  3.963156825432961*^9, 3.963157030143566*^9}, {3.963157066071267*^9, 
  3.963157086762168*^9}},ExpressionUUID->"39e16c75-6ba2-49d7-8182-\
5c7f9b8cfbb5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "find", " ", "values", " ", "of", " ", "m", " ", "and", " ", "\[Epsilon]",
      " ", "from", " ", "term"}], "=", "m\[Epsilon]"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"parseTerm", "[", "term_String", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"m", ",", "eps"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"StringTake", "[", 
          RowBox[{"term", ",", 
           RowBox[{"-", "1"}]}], "]"}], "==", "\"\<+\>\""}], ",", 
        RowBox[{
         RowBox[{"m", "=", 
          RowBox[{"ToExpression", "[", 
           RowBox[{"StringDrop", "[", 
            RowBox[{"term", ",", 
             RowBox[{"-", "1"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"eps", "=", "\"\<+\>\""}], ";"}], ",", 
        RowBox[{
         RowBox[{"m", "=", 
          RowBox[{"ToExpression", "[", 
           RowBox[{"StringDrop", "[", 
            RowBox[{"term", ",", 
             RowBox[{"-", "1"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"eps", "=", "\"\<-\>\""}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"m", ",", "eps"}], "}"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.963152723042045*^9, 3.963152806244215*^9}},
 CellLabel->
