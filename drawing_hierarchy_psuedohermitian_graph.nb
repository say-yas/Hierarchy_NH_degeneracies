Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"imposing", " ", "the", " ", "conversiong_\[Epsilon]", 
      RowBox[{"(", "n", ")"}], " ", "to", " ", 
      RowBox[{"g", "^", 
       RowBox[{"\[Epsilon]", "'"}]}], 
      RowBox[{"(", "n", ")"}], " ", "using", " ", "g_\[Epsilon]", 
      RowBox[{"(", "n", ")"}]}], "=", 
     RowBox[{
      RowBox[{"g", "^", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "^", 
          RowBox[{"{", 
           RowBox[{"n", "-", "1"}], "}"}]}], "\[Epsilon]"}], "}"}]}], 
      RowBox[{"(", "n", ")"}]}]}], ";", " ", 
    RowBox[{
    "Note", " ", "that", " ", "all", " ", "final", " ", "terms", " ", "are", 
     " ", "in", " ", 
     RowBox[{"g", "^", "\[Epsilon]"}], " ", "format"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"convertToGSubEpsilon", "[", 
    RowBox[{"n_Integer", ",", "currentEpsilon_String"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "signFactor", "}"}], ",", 
     RowBox[{
      RowBox[{"signFactor", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}]}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"signFactor", "==", "1"}], ",", "currentEpsilon", ",", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"currentEpsilon", "==", "\"\<+\>\""}], ",", "\"\<-\>\"", 
          ",", "\"\<+\>\""}], "]"}]}], "]"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.963153243856804*^9, 3.9631534450096273`*^9}},
 CellLabel->
  "In[134]:=",ExpressionUUID->"bc36aac6-b5b7-42f6-a9a0-e9bfe2416ecb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"apply", " ", "mutations", " ", "given", " ", "by", " ", 
    RowBox[{"Eqs", ".", " ", 
     RowBox[{"(", 
      RowBox[{"8.1", "-", "8.3"}], ")"}]}], " ", "above"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"applyMutation", "[", 
     RowBox[{
     "chromosome_List", ",", "mutationType_String", ",", "m_Integer", ",", 
      "n_Integer"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"results", "=", 
         RowBox[{"{", "}"}]}], ",", "newChromosome", ",", "term1", ",", 
        "term2", ",", "eps1", ",", "eps2", ",", "newTerm1", ",", "newTerm2", 
        ",", "remainingTerms", ",", "m1", ",", "m2"}], "}"}], ",", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"MemberQ", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"\"\<8.1\>\"", ",", "\"\<8.3\>\""}], "}"}], ",", 
            "mutationType"}], "]"}], "&&", 
          RowBox[{"m", ">", "n"}]}], ",", 
         RowBox[{
          RowBox[{
          "Print", "[", 
           "\"\<Error: For mutation types 8.1 and 8.3, must have m \
\[LessEqual] n\>\"", "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"{", "}"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"mutationType", "==", "\"\<8.2\>\""}], "&&", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"m", "<=", "1"}], "||", 
            RowBox[{"m", ">", "n"}]}], ")"}]}], ",", 
         RowBox[{
          RowBox[{
          "Print", "[", 
           "\"\<Error: For mutation type 8.2, must have 1 < m \[LessEqual] \
n\>\"", "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"{", "}"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"term1", "=", 
           RowBox[{"chromosome", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"term2", "=", 
           RowBox[{"chromosome", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"m1", ",", "eps1"}], "}"}], "=", 
           RowBox[{"parseTerm", "[", "term1", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"m2", ",", "eps2"}], "}"}], "=", 
           RowBox[{"parseTerm", "[", "term2", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Check", " ", "if", " ", "this", " ", "pair", " ", "matches", " ", 
            "the", " ", "mutation", " ", "pattern"}], "*)"}], 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"mutationType", "==", "\"\<8.1\>\""}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m1", "==", "m"}], "&&", 
                  RowBox[{"m2", "==", "n"}], "&&", 
                  RowBox[{"eps1", "!=", "eps2"}]}], ")"}], "||", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m1", "==", "n"}], "&&", 
                  RowBox[{"m2", "==", "m"}], "&&", 
                  RowBox[{"eps1", "!=", "eps2"}]}], ")"}]}], ")"}], ",", 
              RowBox[{
               RowBox[{"remainingTerms", "=", 
                RowBox[{"Delete", "[", 
                 RowBox[{"chromosome", ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"{", "i", "}"}], ",", 
                    RowBox[{"{", "j", "}"}]}], "}"}]}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"m1", "==", "m"}], ",", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"newEps2", "=", "eps1"}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"newEps1", " ", "=", "eps2"}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"newTerm1", "=", 
                   RowBox[{"makeTerm", "[", 
                    RowBox[{
                    RowBox[{"m", "-", "1"}], ",", "newEps1"}], "]"}]}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"newTerm2", "=", 
                   RowBox[{"makeTerm", "[", 
                    RowBox[{
                    RowBox[{"n", "+", "1"}], ",", "newEps2"}], "]"}]}], ";"}],
                  ",", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"newEps2", "=", "eps2"}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"newEps1", " ", "=", "eps1"}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"newTerm1", "=", 
                   RowBox[{"makeTerm", "[", 
                    RowBox[{
                    RowBox[{"m", "-", "1"}], ",", "newEps1"}], "]"}]}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"newTerm2", "=", 
                   RowBox[{"makeTerm", "[", 
                    RowBox[{
                    RowBox[{"n", "+", "1"}], ",", "newEps2"}], "]"}]}], 
                  ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
               RowBox[{"newChromosome", "=", 
                RowBox[{"Join", "[", 
                 RowBox[{"remainingTerms", ",", 
                  RowBox[{"{", 
                   RowBox[{"newTerm1", ",", "newTerm2"}], "}"}]}], "]"}]}], 
               ";", "\[IndentingNewLine]", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"results", ",", "newChromosome"}], "]"}], ";"}]}], 
             "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"mutationType", "==", "\"\<8.2\>\""}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m1", "==", "m"}], "&&", 
                  RowBox[{"m2", "==", "n"}], "&&", 
                  RowBox[{"eps1", "==", "eps2"}]}], ")"}], "||", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"m1", "==", "n"}], "&&", 
                  RowBox[{"m2", "==", "m"}], "&&", 
                  RowBox[{"eps1", "==", "eps2"}]}], ")"}]}], ")"}], ",", 
              RowBox[{
               RowBox[{"remainingTerms", "=", 
                RowBox[{"Delete", "[", 
                 RowBox[{"chromosome", ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"{", "i", "}"}], ",", 
                    RowBox[{"{", "j", "}"}]}], "}"}]}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"newTerm1", "=", 
                RowBox[{"makeTerm", "[", 
                 RowBox[{
                  RowBox[{"m", "-", "2"}], ",", "eps1"}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"newTerm2", "=", 
                RowBox[{"makeTerm", "[", 
                 RowBox[{
                  RowBox[{"n", "+", "2"}], ",", "eps1"}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"newChromosome", "=", 
                RowBox[{"Join", "[", 
                 RowBox[{"remainingTerms", ",", 
                  RowBox[{"{", 
                   RowBox[{"newTerm1", ",", "newTerm2"}], "}"}]}], "]"}]}], 
               ";", "\[IndentingNewLine]", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"results", ",", "newChromosome"}], "]"}], ";"}]}], 
             "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"mutationType", "==", "\"\<8.3\>\""}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Module", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
               "gSubEpsM", ",", "gSubEpsN", ",", "requiredEpsM", ",", 
                "requiredEpsN"}], "}"}], ",", 
              RowBox[{
               RowBox[{"gSubEpsM", "=", 
                RowBox[{"convertToGSubEpsilon", "[", 
                 RowBox[{"m1", ",", "eps1"}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"gSubEpsN", "=", 
                RowBox[{"convertToGSubEpsilon", "[", 
                 RowBox[{"m2", ",", "eps2"}], "]"}]}], ";", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"m1", "==", "m"}], "&&", 
                    RowBox[{"m2", "==", "n"}], "&&", 
                    RowBox[{"gSubEpsM", "!=", "gSubEpsN"}]}], ")"}], "||", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"m1", "==", "n"}], "&&", 
                    RowBox[{"m2", "==", "m"}], "&&", 
                    RowBox[{"gSubEpsM", "!=", "gSubEpsN"}]}], ")"}]}], ")"}], 
                 ",", 
                 RowBox[{
                  RowBox[{"remainingTerms", "=", 
                   RowBox[{"Delete", "[", 
                    RowBox[{"chromosome", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", "i", "}"}], ",", 
                    RowBox[{"{", "j", "}"}]}], "}"}]}], "]"}]}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{"m1", "==", "m"}], ",", 
                    RowBox[{
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"newEps1", ",", "newEps2"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"newEps1", "=", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"-", "1"}], ")"}], "^", 
                    RowBox[{"(", 
                    RowBox[{"m", "-", "2"}], ")"}]}], "==", "1"}], ",", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"gSubEpsM", "==", "\"\<+\>\""}], ",", "\"\<-\>\"",
                     ",", "\"\<+\>\""}], "]"}], ",", "gSubEpsM"}], "  ", 
                    "]"}]}], ";", "\[IndentingNewLine]", 
                    RowBox[{"newEps2", "=", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"-", "1"}], ")"}], "^", "n"}], "==", "1"}], ",", 
                    "gSubEpsM", ",", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"gSubEpsM", "==", "\"\<+\>\""}], ",", "\"\<-\>\"",
                     ",", "\"\<+\>\""}], "]"}]}], "  ", "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"newTerm1", "=", 
                    RowBox[{"makeTerm", "[", 
                    RowBox[{
                    RowBox[{"m", "-", "1"}], ",", "newEps1"}], "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"newTerm2", "=", 
                    RowBox[{"makeTerm", "[", 
                    RowBox[{
                    RowBox[{"n", "+", "1"}], ",", "newEps2"}], "]"}]}], 
                    ";"}]}], "]"}], ";"}], ",", 
                    RowBox[{
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"newEps1", ",", "newEps2"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"newEps1", "=", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"-", "1"}], ")"}], "^", 
                    RowBox[{"(", 
                    RowBox[{"m", "-", "2"}], ")"}]}], "==", "1"}], ",", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"gSubEpsN", "==", "\"\<+\>\""}], ",", "\"\<-\>\"",
                     ",", "\"\<+\>\""}], "]"}], ",", "gSubEpsN"}], "]"}]}], 
                    ";", "\[IndentingNewLine]", 
                    RowBox[{"newEps2", "=", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"-", "1"}], ")"}], "^", "n"}], "==", "1"}], ",", 
                    "gSubEpsN", ",", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"gSubEpsN", "==", "\"\<+\>\""}], ",", "\"\<-\>\"",
                     ",", "\"\<+\>\""}], "]"}]}], "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"newTerm1", "=", 
                    RowBox[{"makeTerm", "[", 
                    RowBox[{
                    RowBox[{"m", "-", "1"}], ",", "newEps1"}], "]"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"newTerm2", "=", 
                    RowBox[{"makeTerm", "[", 
                    RowBox[{
                    RowBox[{"n", "+", "1"}], ",", "newEps2"}], "]"}]}], 
                    ";"}]}], "]"}], ";"}]}], "]"}], ";", 
                  "\[IndentingNewLine]", 
                  RowBox[{"newChromosome", "=", 
                   RowBox[{"Join", "[", 
                    RowBox[{"remainingTerms", ",", 
                    RowBox[{"{", 
                    RowBox[{"newTerm1", ",", "newTerm2"}], "}"}]}], "]"}]}], 
                  ";", "\[IndentingNewLine]", 
                  RowBox[{"AppendTo", "[", 
                   RowBox[{"results", ",", "newChromosome"}], "]"}], ";"}]}], 
                "]"}]}]}], "]"}]}], "]"}], ";"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{
            RowBox[{"Length", "[", "chromosome", "]"}], "-", "1"}]}], "}"}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"i", "+", "1"}], ",", 
           RowBox[{"Length", "[", "chromosome", "]"}]}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Map", "[", 
        RowBox[{"filterZeroTerms", ",", "results"}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
