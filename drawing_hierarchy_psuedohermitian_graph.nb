Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"create", " ", "directed", " ", "mutation", " ", 
    RowBox[{"tree", ":", " ", 
     RowBox[{"inputs", 
      RowBox[{"(", 
       RowBox[{"startchromosoms", ",", " ", 
        RowBox[{"maxdepth", " ", "of", " ", "tree"}], ",", " ", "max_m"}], 
       ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"createDirectedMutationTree", "[", 
    RowBox[{"startChromosome_List", ",", 
     RowBox[{"maxDepth_Integer", ":", "10"}], ",", 
     RowBox[{"maxValue_Integer", ":", "40"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "currentLevel", ",", "allNodes", ",", "allEdges", ",", "depth", ",", 
       "nodeCounter", ",", "nodeMap", ",", "nodeLevels"}], "}"}], ",", 
     RowBox[{
      RowBox[{"currentLevel", "=", 
       RowBox[{"{", "startChromosome", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"allNodes", "=", 
       RowBox[{"{", "startChromosome", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"allEdges", "=", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"nodeCounter", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"nodeMap", "=", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"ToString", "[", "startChromosome", "]"}], "->", "1"}], 
        "|>"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"nodeLevels", "=", 
       RowBox[{"<|", 
        RowBox[{"1", "->", "0"}], "|>"}]}], ";", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"depth", "=", "0"}], ",", 
        RowBox[{"depth", "<", "maxDepth"}], ",", 
        RowBox[{"depth", "++"}], ",", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "nextLevel", "}"}], ",", 
          RowBox[{
           RowBox[{"nextLevel", "=", 
            RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"Module", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"mutations", ",", "parentKey", ",", "parentID"}], 
                "}"}], ",", 
               RowBox[{
                RowBox[{"parentKey", "=", 
                 RowBox[{"ToString", "[", 
                  RowBox[{"sortChromosomeCompact", "[", "chromosome", "]"}], 
                  "]"}]}], ";", "\[IndentingNewLine]", 
                RowBox[{"parentID", "=", 
                 RowBox[{"nodeMap", "[", "parentKey", "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"mutations", "=", 
                 RowBox[{"findAllMutations", "[", 
                  RowBox[{
                   RowBox[{"sortChromosomeCompact", "[", "chromosome", "]"}], 
                   ",", "maxValue"}], "]"}]}], ";", "\[IndentingNewLine]", 
                RowBox[{"Do", "[", 
                 RowBox[{
                  RowBox[{"Module", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    "mutationType", ",", "m", ",", "n", ",", "results"}], 
                    "}"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    "mutationType", ",", "m", ",", "n", ",", "results"}], 
                    "}"}], "=", "mutation"}], ";", "\[IndentingNewLine]", 
                    RowBox[{"Do", "[", 
                    RowBox[{
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"childKey", ",", "childID"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"childKey", "=", 
                    RowBox[{"ToString", "[", 
                    RowBox[{"sortChromosomeCompact", "[", "result", "]"}], 
                    "]"}]}], ";", "\[IndentingNewLine]", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"!", 
                    RowBox[{"KeyExistsQ", "[", 
                    RowBox[{"nodeMap", ",", "childKey"}], "]"}]}], ",", 
                    RowBox[{
                    RowBox[{"AppendTo", "[", 
                    RowBox[{"allNodes", ",", 
                    RowBox[{"sortChromosomeCompact", "[", "result", "]"}]}], 
                    "]"}], ";", "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"nodeMap", "[", "childKey", "]"}], "=", 
                    RowBox[{"++", "nodeCounter"}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"nodeLevels", "[", "nodeCounter", "]"}], "=", 
                    RowBox[{"depth", "+", "1"}]}], ";"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"childID", "=", 
                    RowBox[{"nodeMap", "[", "childKey", "]"}]}], ";", 
                    RowBox[{"AppendTo", "[", 
                    RowBox[{"allEdges", ",", 
                    RowBox[{"<|", 
                    RowBox[{
                    RowBox[{"\"\<from\>\"", "->", "parentID"}], ",", 
                    RowBox[{"\"\<to\>\"", "->", "childID"}], ",", 
                    RowBox[{"\"\<mutationType\>\"", "->", "mutationType"}], 
                    ",", 
                    RowBox[{"\"\<m\>\"", "->", "m"}], ",", 
                    RowBox[{"\"\<n\>\"", "->", "n"}], ",", 
                    RowBox[{"\"\<fromLevel\>\"", "->", "depth"}], ",", 
                    RowBox[{"\"\<toLevel\>\"", "->", 
                    RowBox[{"depth", "+", "1"}]}], ",", 
                    RowBox[{"\"\<label\>\"", "->", 
                    RowBox[{"mutationType", "<>", "\"\<\\n(m=\>\"", "<>", 
                    RowBox[{"ToString", "[", "m", "]"}], "<>", "\"\<,n=\>\"", 
                    "<>", 
                    RowBox[{"ToString", "[", "n", "]"}], "<>", 
                    "\"\<)\>\""}]}]}], "|>"}]}], "]"}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"AppendTo", "[", 
                    RowBox[{"nextLevel", ",", "result"}], "]"}], ";"}]}], 
                    "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"result", ",", "results"}], "}"}]}], "]"}]}]}], 
                   "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"mutation", ",", "mutations"}], "}"}]}], "]"}]}]}],
               "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"chromosome", ",", "currentLevel"}], "}"}]}], "]"}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"currentLevel", "=", 
            RowBox[{"DeleteDuplicates", "[", "nextLevel", "]"}]}], ";"}]}], 
         "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"allNodes", ",", 
        RowBox[{"Select", "[", 
         RowBox[{"allEdges", ",", 
          RowBox[{
           RowBox[{"!", 
            RowBox[{"MissingQ", "[", 
             RowBox[{"#", "[", "\"\<from\>\"", "]"}], "]"}]}], "&"}]}], "]"}],
         ",", "nodeMap", ",", "nodeLevels"}], "}"}]}]}], "]"}]}]}]], "Input",
