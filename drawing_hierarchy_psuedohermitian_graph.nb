Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "create", " ", "mutation", " ", "tree", " ", "with", " ", "given", " ", 
    "depth", " ", "and", " ", "max", " ", "m", " ", 
    RowBox[{"value", ".", " ", "edge"}], " ", "labels", " ", "are", " ", 
    "mutation", " ", "equation", " ", "and", " ", "by", " ", "default", " ", 
    "is", " ", "not", " ", "shown"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"createGraphMutationTree", "[", 
    RowBox[{"startChromosome_List", ",", 
     RowBox[{"maxDepth_Integer", ":", "10"}], ",", 
     RowBox[{"maxValue_Integer", ":", "40"}], ",", 
     RowBox[{"showEdgeLabels_", ":", "False"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "nodes", ",", "edges", ",", "nodeMap", ",", "nodeLevels", ",", 
       "graphEdges", ",", "vertexLabels", ",", "uniqueEdges", ",", 
       "edgeLabels", ",", "graphOptions"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"nodes", ",", "edges", ",", "nodeMap", ",", "nodeLevels"}], 
        "}"}], "=", 
       RowBox[{"createDirectedMutationTree", "[", 
        RowBox[{
         RowBox[{"sortChromosomeCompact", "[", "startChromosome", "]"}], ",", 
         "maxDepth", ",", "maxValue"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "edges", "]"}], "==", "0"}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"Graphics", "[", 
          RowBox[{"{", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<No mutations found\>\"", ",", 
               RowBox[{"FontSize", "->", "14"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}]}], "]"}], "}"}], "]"}], "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"graphEdges", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"DirectedEdge", "[", 
           RowBox[{
            RowBox[{"#", "[", "\"\<from\>\"", "]"}], ",", 
            RowBox[{"#", "[", "\"\<to\>\"", "]"}]}], "]"}], "&"}], ",", 
         "edges"}], "]"}]}], ";", 
      RowBox[{"uniqueEdges", "=", 
       RowBox[{"DeleteDuplicates", "[", "graphEdges", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"vertexLabels", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"i", "->", 
          RowBox[{"formatChromosome", "[", 
           RowBox[{"nodes", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "nodes", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"showEdgeLabels", ",", 
        RowBox[{
         RowBox[{"edgeLabels", "=", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"DirectedEdge", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"edges", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "[", "\"\<from\>\"", "]"}], 
               ",", 
               RowBox[{
                RowBox[{"edges", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "[", "\"\<to\>\"", "]"}]}], 
              "]"}], "->", 
             RowBox[{
              RowBox[{"edges", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "[", "\"\<label\>\"", "]"}]}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", 
              RowBox[{"Length", "[", "edges", "]"}]}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"edgeLabels", "=", 
          RowBox[{"DeleteDuplicatesBy", "[", 
           RowBox[{"edgeLabels", ",", "First"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"graphOptions", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"VertexLabels", "->", "vertexLabels"}], ",", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{"VertexLabelStyle", "->", "20"}], ","}], "*)"}], 
            RowBox[{"EdgeLabels", "->", "edgeLabels"}], ",", 
            RowBox[{"EdgeStyle", "->", "Blue"}], ",", 
            RowBox[{"VertexStyle", "->", "Black"}], ",", 
            RowBox[{"GraphLayout", "->", "\"\<LayeredDigraphEmbedding\>\""}], 
            ",", 
            RowBox[{"PlotLabel", "->", 
             RowBox[{"Style", "[", 
              RowBox[{
               RowBox[{"\"\<Mutation Tree: \>\"", "<>", 
                RowBox[{"formatChromosome", "[", "startChromosome", "]"}]}], 
               ",", "Bold", ",", 
               RowBox[{"FontSize", "->", "17"}]}], "]"}]}], ",", 
            RowBox[{"ImageSize", "->", "Large"}], ",", 
            RowBox[{"VertexSize", "->", "Small"}]}], "}"}]}]}], ",", 
        RowBox[{"graphOptions", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"VertexLabels", "->", "vertexLabels"}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"VertexLabelStyle", "->", "20"}], ","}], "*)"}], 
           RowBox[{"EdgeStyle", "->", "Blue"}], ",", 
           RowBox[{"VertexStyle", "->", "Black"}], ",", 
           RowBox[{"GraphLayout", "->", "\"\<LayeredDigraphEmbedding\>\""}], 
           ",", 
           RowBox[{"PlotLabel", "->", 
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"\"\<Mutation Tree: \>\"", "<>", 
               RowBox[{"formatChromosome", "[", "startChromosome", "]"}]}], 
              ",", "Bold", ",", 
              RowBox[{"FontSize", "->", "17"}]}], "]"}]}], ",", 
           RowBox[{"ImageSize", "->", "Large"}], ",", 
           RowBox[{"VertexSize", "->", "Small"}]}], "}"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ReverseGraph", "[", 
       RowBox[{"Graph", "[", 
        RowBox[{"uniqueEdges", ",", 
         RowBox[{"Sequence", "@@", "graphOptions"}]}], "]"}], "]"}]}]}], 
    "]"}]}]}]], "Input",
