    RowBox[{"find", " ", "term"}], "=", 
    RowBox[{
    "m\[Epsilon]", " ", "given", " ", "m", " ", "and", " ", "\[Epsilon]"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"makeTerm", "[", 
    RowBox[{"m_Integer", ",", "eps_String"}], "]"}], ":=", 
